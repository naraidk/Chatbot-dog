<div class="container mt-4">
      <h1 class="mb-4">Créer le profil de mon chien</h1>

      <%= form_with model: @dog do |f| %>
        <div class="mb-3">
          <%= f.label :name, "Nom", class: "form-label" %>
          <%= f.text_field :name, class: "form-control", placeholder: "Ex: Rocky" %>
        </div>

        <div class="mb-3">
          <%= f.label :breed, "Race", class: "form-label" %>
          <%= f.text_field :breed, class: "form-control", placeholder: "Ex: Labrador" %>
        </div>

        <div class="mb-3">
          <%= f.label :age, "Âge", class: "form-label" %>
          <%= f.number_field :age, class: "form-control", placeholder: "Ex: 3" %>
        </div>

        <div class="mb-3">
          <%= f.label :description, "Description", class: "form-label" %>
          <%= f.text_area :description, class: "form-control", rows: 4, placeholder: "Décris ton chien..." %>
        </div>

        <%= f.submit "Créer mon chien", class: "btn btn-primary" %>
      <% end %>
</div>
