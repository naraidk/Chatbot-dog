<div class="container py-5">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="fw-bold">Mes chiens</h1>
      <p class="text-muted">
        Gère les profils de tes chiens.
      </p>
    </div>

    <%= link_to "Ajouter un chien",
        new_dog_path,
        class: "btn btn-primary rounded-pill px-4" %>
  </div>

  <% if @dogs.any? %>

    <div class="row g-4">

      <% @dogs.each do |dog| %>

        <div class="col-md-4">

          <div class="card h-100 shadow-sm rounded-4 border-0">

            <div class="card-body p-4">

              <% if dog.photo.attached? %>
                <%= cl_image_tag dog.photo.key,
                    width: 120, height: 120, crop: :fill,
                    class: "rounded-circle mb-3" %>
              <% end %>

              <h3 class="fw-bold">
                <%= dog.name %>
              </h3>

              <p class="text-muted mb-1">
                Race : <%= dog.breed %>
              </p>

              <p>
                Âge : <%= dog.age || "Non renseigné" %> ans
              </p>

              <div class="d-grid gap-2 mt-4">

                <%= link_to "Voir profil",
                    dog_path(dog),
                    class: "btn btn-outline-primary rounded-pill" %>

                <%= button_to "Assistant de #{dog.name}",
                    dog_chats_path(dog),
                    method: :post,
                    class: "btn btn-primary rounded-pill" %>

              </div>

            </div>

          </div>

        </div>

      <% end %>

    </div>

  <% else %>

    <div class="bg-light rounded-4 p-5 text-center">

      <h3 class="fw-bold">
        Aucun chien enregistré
      </h3>

      <p class="text-muted">
        Ajoute ton premier chien pour commencer.
      </p>

    </div>

  <% end %>

</div>
