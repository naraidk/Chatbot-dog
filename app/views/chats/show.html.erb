<div class="container-fluid vh-90 p-5">

  <div class="row h-100 m-0">

    <!-- SIDEBAR -->
    <div class="col-md-3 border-end bg-white d-none d-md-flex flex-column p-4">

      <h4 class="fw-bold mb-4 text-orange">
       <%= image_tag "doggy.svg", class: "img-fluid", style: "width: 100px;" %>
      </h4>

      <h6 class="text-muted mb-3">
        Anciennes discussions
      </h6>

      <% current_user.chats.each do |chat| %>

        <%= link_to chat.title,
            chat_path(chat),
            class: "text-decoration-none text-dark mb-3 d-block" %>

      <% end %>

      <div class="mt-auto">

        <%= link_to "Mes chiens",
            dogs_path,
            class: "btn btn-outline-primary rounded-pill w-100 mb-2" %>

        <%= button_to "Déconnexion",
            destroy_user_session_path,
            method: :delete,
            class: "btn btn-danger rounded-pill w-100" %>


      </div>

    </div>

    <!-- CHAT -->
    <div class="col d-flex flex-column bg-light p-0">

      <!-- HEADER -->
      <div class="bg-white border-bottom p-3">

        <h4 class="fw-bold mb-0">
          <%= @chat.dog.name %>
        </h4>

        <small class="text-muted">
          Assistant IA Doggy
        </small>

      </div>

      <!-- MESSAGES -->
      <div class="flex-grow-1 overflow-auto p-4">
        <% if @messages.any? %>
        <% @chat.messages.each do |message| %>
        <% if message.persisted? %>
          <% if message.role == "user" %>

            <div class="d-flex justify-content-end mb-3">

              <div class="bg-doggy text-white p-3 rounded-4"
                   style="max-width: 75%;">

                <%= message.content %>

              </div>

            </div>

          <% else %>

            <div class="d-flex justify-content-start mb-3">

              <div class="bg-white p-3 rounded-4 shadow-sm"
                   style="max-width: 75%;">

              <div class="message-content">
                <%= simple_format(message.content) %>

              </div>
              </div>
            </div>

          <% end %>

        <% end %>
        <% end %>
  <% else %>
<div class=“text-center text-muted mt-5">
<p>Posez votre première question ci-dessous pour démarrer la conversation !</p>
</div>

<% end %>

      </div>

      <!-- INPUT -->
      <div class="bg-white border-top p-3 mb-3">

        <%= form_with model: [@chat, @message] do |form| %>

          <div class="d-flex align-items-center">

            <%= form.text_field :content,
                class: "form-control rounded-pill px-4 py-3 me-2 border-0 bg-light",
                placeholder: "Écris un message..." %>

            <%= form.submit "➜",
                class: "btn btn-orange rounded-circle",
                style: "width: 50px; height: 50px;" %>

          </div>

        <% end %>

      </div>

      </div>

    </div>

  </div>

</div>
