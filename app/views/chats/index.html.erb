<div class="container py-5">

  <div class="d-flex justify-content-between align-items-center mb-4">

    <div>

      <h1 class="fw-bold">
        Conversations
      </h1>

      <p class="text-muted">
        Retrouve tes anciennes discussions.
      </p>

    </div>

    <%= link_to "Mes chiens",
        dogs_path,
        class: "btn btn-primary rounded-pill px-4" %>

  </div>

  <% if @chats.any? %>

    <div class="row g-4">

      <% @chats.each do |chat| %>

        <div class="col-md-4">

          <div class="card border-0 shadow-sm rounded-4 h-100">

            <div class="card-body p-4">

              <h5 class="fw-bold">
                <%= chat.title %>
              </h5>

              <p class="text-muted">
                Chien : <%= chat.dog.name %>
              </p>

              <%= link_to "Ouvrir",
                  chat_path(chat),
                  class: "btn btn-orange rounded-pill w-100" %>

            </div>

          </div>

        </div>

      <% end %>

    </div>

  <% else %>

    <div class="bg-white rounded-4 shadow-sm p-5 text-center">

      <h3 class="fw-bold">
        Aucune conversation
      </h3>

    </div>

  <% end %>

</div>
