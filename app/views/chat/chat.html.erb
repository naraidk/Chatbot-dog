                </svg>
            </div>
            <!-- Bouton Hamburger : Uniquement visible sur mobile pour ouvrir l'historique -->
            <button class="btn border-0 d-md-none fs-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#historiqueMobile">
                <i class="fa-solid fa-bars"></i>
            </button>
        </header>

        <!-- CORPS DE LA PAGE (DISPOSITION EN GRILLE) -->
        <div class="row flex-grow-1 m-0 overflow-hidden bg-white">

            <!-- HISTORIQUE PC : Colonne latérale gauche (Cachée sur mobile, visible sur PC) -->
            <div class="col-md-4 col-lg-3 border-end d-none d-md-flex flex-column p-3 bg-light overflow-auto">
                <h5 class="fw-bold mb-4 text-secondary fs-6">Anciennes discussions</h5>
                <ul class="list-group list-group-flush bg-transparent">
                    <li class="list-group-item bg-transparent border-0 px-0 mb-2"><a href="#" class="text-decoration-none text-dark"><i class="fa-regular fa-comment me-2 text-muted"></i> Santé de Max</a></li>
                    <li class="list-group-item bg-transparent border-0 px-0 mb-2"><a href="#" class="text-decoration-none text-dark"><i class="fa-regular fa-comment me-2 text-muted"></i> Croquettes sans céréales</a></li>
                    <li class="list-group-item bg-transparent border-0 px-0 mb-2"><a href="#" class="text-decoration-none text-dark"><i class="fa-regular fa-comment me-2 text-muted"></i> Dressage chiot</a></li>
                </ul>
            </div>

            <!-- HISTORIQUE MOBILE : Tiroir coulissant (Offcanvas) qui s'ouvre au clic sur le hamburger -->
            <div class="offcanvas offcanvas-end d-md-none" tabindex="-1" id="historiqueMobile">
                <div class="offcanvas-header border-bottom">
                    <h5 class="offcanvas-title fw-bold text-doggy">Anciennes discussions</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Fermer"></button>
                </div>
                <div class="offcanvas-body bg-light">
                    <ul class="list-group list-group-flush bg-transparent">
                        <li class="list-group-item bg-transparent border-0 px-0 mb-2"><a href="#" class="text-decoration-none text-dark"><i class="fa-regular fa-comment me-2"></i> Santé de Max</a></li>
                        <li class="list-group-item bg-transparent border-0 px-0 mb-2"><a href="#" class="text-decoration-none text-dark"><i class="fa-regular fa-comment me-2"></i> Croquettes sans céréales</a></li>
                    </ul>
                </div>
            </div>

            <!-- ZONE DE DISCUSSION & NAVIGATION COMMUNE -->
            <div class="col flex-grow-1 d-flex flex-column p-0 position-relative">

                <!-- Fenêtre contenant les bulles de messages -->
                <div class="chat-container flex-grow-1 p-3 p-md-4 overflow-auto" id="chatWindow">

                    <!-- Message automatique de l'IA assistant -->
                    <div class="message-wrapper ai-wrapper mb-4">
                        <small class="text-muted d-block mb-1 ms-1">ai assistant</small>
                        <div class="message ai-message p-3 rounded-4 shadow-sm">
                            Wouf ! Comment puis-je t'aider avec ton chien aujourd'hui ? 🐾
                        </div>
                    </div>

                </div>

                <!-- Zone de saisie (Formulaire avec champ texte) -->
                <div class="input-area p-3 bg-white border-top">
                    <form id="chatForm" class="d-flex align-items-center">
                        <input type="text" id="userInput" class="form-control rounded-pill px-4 py-3 me-2 bg-light border-0 shadow-none" placeholder="Ecrivez ici..." autocomplete="off">
                        <!-- Le bouton Envoyer est caché, l'envoi se fait via la touche Entrée du clavier -->
                        <button type="submit" class="btn btn-doggy rounded-circle text-white d-none" style="width: 50px; height: 50px;">
                            <i class="fa-solid fa-paper-plane"></i>
                        </button>
                    </form>
                </div>

                <!-- BARRE DE NAVIGATION COMMUNE (TOUJOURS EN BAS : Mobile ET PC) -->
                <nav class="bottom-nav border-top bg-white d-flex justify-content-around align-items-center py-3">
                    <a href="#" class="text-dark fs-3" title="Accueil"><i class="fa-solid fa-house"></i></a>
                    <a href="#" class="text-dark fs-3" title="Carte"><i class="fa-solid fa-map-location-dot"></i></a>
                    <a href="#" class="text-dark fs-3" title="Calendrier"><i class="fa-solid fa-calendar-days"></i></a>
                    <!-- L'icône du Chat est colorée en orange car nous sommes dans la section Chat -->
                    <a href="#" class="text-doggy fs-3" title="Chatbot active"><i class="fa-solid fa-comment-dots"></i></a>
                    <a href="#" class="text-dark fs-3" title="Profil"><i class="fa-solid fa-user"></i></a>
                </nav>

            </div>
        </div>
    </div>

    <!-- Script Bootstrap JavaScript (Gère l'ouverture de l'historique mobile) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Notre logique JavaScript simplifiée -->
    <script src="app.js"></script>
</body>
</html>
