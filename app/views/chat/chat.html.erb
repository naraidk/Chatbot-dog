<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Doggy - Chatbot</title>
    <!-- Bootstrap : pour la structure de la page et le responsive -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome : pour afficher les pictogrammes (icônes) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Notre propre fichier de style CSS -->
    <link rel="stylesheet" href="../assets/stylesheets/application.scss">
    <style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap');
</style>
</head>
<body class="bg-light p-lg-4">

    <!-- CONTAINER PRINCIPAL : Aligné au centre avec une largeur maximale de 1200px -->
    <div class="container-fluid h-100 d-flex flex-column p-0 bg-white shadow-sm" style="max-width: 1200px; margin: auto;">

        <!-- EN-TÊTE (HEADER) : Contient le logo SVG et le menu pour l'historique -->
        <header class="d-flex justify-content-between align-items-center p-3 border-bottom bg-white">
            <!-- Logo SVG officiel Doggy -->
            <div class="logo">
